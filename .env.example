# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EmailJS — used for appointment notification emails
# Sign up at https://www.emailjs.com/ and create a service + template
VITE_EMAILJS_PUBLIC_KEY="YOUR_EMAILJS_PUBLIC_KEY"
VITE_EMAILJS_SERVICE_ID="YOUR_EMAILJS_SERVICE_ID"
VITE_EMAILJS_TEMPLATE_ID="YOUR_EMAILJS_TEMPLATE_ID"

# Stripe Payment Links (create in Stripe Dashboard > Payment Links)
# Each link should redirect back to: https://reflect-medical.web.app/dashboard?membership=activated
VITE_STRIPE_LINK_CORE_MONTHLY=
VITE_STRIPE_LINK_CORE_ANNUAL=
VITE_STRIPE_LINK_EVOLVE_MONTHLY=
VITE_STRIPE_LINK_EVOLVE_ANNUAL=
VITE_STRIPE_LINK_TRANSFORM_MONTHLY=
VITE_STRIPE_LINK_TRANSFORM_ANNUAL=
