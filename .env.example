# Environment Variables - Reflect Medical Premium
# Copy to .env and fill in your real values

# ─── Firebase ───────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Stripe ─────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── EmailJS ─────────────────────────────────────────────────────────────────
# Get these from https://dashboard.emailjs.com
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Template IDs — create one template per use case in EmailJS dashboard
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx            # Legacy: general notification to office

# Notification-specific templates (Feature 4)
VITE_EMAILJS_TEMPLATE_CONFIRMATION=template_xxxxxxx  # Sent to patient on booking
VITE_EMAILJS_TEMPLATE_REMINDER=template_xxxxxxx      # Sent to patient as reminder
VITE_EMAILJS_TEMPLATE_FOLLOWUP=template_xxxxxxx      # Post-visit follow-up with Google review link
VITE_EMAILJS_TEMPLATE_OFFICE=template_xxxxxxx        # Internal alert to office on new booking
